{
  "name": "via-vscode",
  "displayName": "VIA Runner",
  "description": "Run Virtuoso .il files and code snippets through the via CLI from VS Code.",
  "version": "0.0.1",
  "publisher": "si-view",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/si-view/via-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/si-view/via-vscode/issues"
  },
  "homepage": "https://github.com/si-view/via-vscode#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:skill",
    "onCommand:via.configureWorkspace",
    "onCommand:via.configureSession",
    "onCommand:via.selectWorkspace",
    "onCommand:via.createWorkspace",
    "onCommand:via.showStatusMenu",
    "onCommand:via.showStatusDetails",
    "onCommand:via.refreshConnectionStatus",
    "onCommand:via.startWorkspace",
    "onCommand:via.startKernel",
    "onCommand:via.runFile",
    "onCommand:via.runSelection"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "via.configureWorkspace",
        "title": "VIA: Configure Workspace",
        "category": "VIA",
        "icon": "$(gear)"
      },
      {
        "command": "via.selectWorkspace",
        "title": "VIA: Select Workspace",
        "category": "VIA",
        "icon": "$(server-process)"
      },
      {
        "command": "via.createWorkspace",
        "title": "VIA: New Workspace",
        "category": "VIA",
        "icon": "$(add)"
      },
      {
        "command": "via.startWorkspace",
        "title": "VIA: Start Workspace",
        "category": "VIA",
        "icon": "$(debug-start)"
      },
      {
        "command": "via.refreshConnectionStatus",
        "title": "VIA: Refresh Connection Status",
        "category": "VIA",
        "icon": "$(refresh)"
      },
      {
        "command": "via.showStatusDetails",
        "title": "VIA: Show Status Details",
        "category": "VIA",
        "icon": "$(list-unordered)"
      },
      {
        "command": "via.runFile",
        "title": "VIA: Run Current File",
        "category": "VIA",
        "icon": "$(play)"
      },
      {
        "command": "via.runSelection",
        "title": "VIA: Run Selection or Paragraph",
        "category": "VIA",
        "icon": "$(run-all)"
      }
    ],
    "configuration": {
      "title": "VIA Runner",
      "properties": {
        "via.commandPath": {
          "type": "string",
          "default": "via",
          "description": "Path to the via executable."
        },
        "via.language": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "zh"
          ],
          "default": "auto",
          "markdownDescription": "Language used by the VIA Runner runtime UI. `auto` follows the VS Code display language."
        },
        "via.defaultWorkspace": {
          "type": "string",
          "default": "",
          "description": "Default Virtuoso workspace path used when starting via."
        },
        "via.defaultInstanceName": {
          "type": "string",
          "default": "vscode",
          "description": "Default via instance name used behind the scenes."
        },
        "via.displayMode": {
          "type": "string",
          "enum": [
            "inherit",
            "custom",
            "unset"
          ],
          "default": "inherit",
          "description": "How DISPLAY is passed to via commands."
        },
        "via.displayValue": {
          "type": "string",
          "default": "",
          "description": "DISPLAY value used when via.displayMode is set to custom, for example :0 or localhost:10.0."
        },
        "via.knownWorkspaces": {
          "type": "array",
          "default": [],
          "description": "Known via workspace presets shown in the workspace selector.",
          "items": {
            "type": "object",
            "properties": {
              "instanceName": {
                "type": "string"
              },
              "workspacePath": {
                "type": "string"
              }
            }
          }
        },
        "via.knownKernels": {
          "type": "array",
          "default": [],
          "description": "Known via workspace presets shown in the workspace selector.",
          "deprecationMessage": "Use via.knownWorkspaces instead.",
          "items": {
            "type": "object",
            "properties": {
              "instanceName": {
                "type": "string"
              },
              "workspacePath": {
                "type": "string"
              }
            }
          }
        },
        "via.autoStartWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "Start via automatically for the selected workspace before running a file or selection when needed."
        },
        "via.useDisplay": {
          "type": "boolean",
          "default": true,
          "description": "Whether to pass DISPLAY to via commands.",
          "deprecationMessage": "Use via.displayMode instead."
        },
        "via.autoStartKernel": {
          "type": "boolean",
          "default": true,
          "description": "Start via automatically for the selected workspace before running a file or selection when needed.",
          "deprecationMessage": "Use via.autoStartWorkspace instead."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "via.selectWorkspace",
          "when": "resourceExtname == .il",
          "group": "navigation@9"
        },
        {
          "command": "via.runFile",
          "when": "resourceExtname == .il",
          "group": "navigation@10"
        },
        {
          "command": "via.runSelection",
          "when": "resourceExtname == .il",
          "group": "navigation@11"
        }
      ],
      "commandPalette": [
        {
          "command": "via.configureWorkspace"
        },
        {
          "command": "via.startWorkspace"
        },
        {
          "command": "via.refreshConnectionStatus"
        },
        {
          "command": "via.showStatusDetails"
        },
        {
          "command": "via.selectWorkspace"
        },
        {
          "command": "via.createWorkspace"
        },
        {
          "command": "via.runFile"
        },
        {
          "command": "via.runSelection"
        }
      ]
    },
    "languages": [
      {
        "id": "skill",
        "aliases": [
          "Skill"
        ],
        "extensions": [
          ".il"
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "npm run lint"
  },
  "keywords": [
    "via",
    "virtuoso",
    "skill",
    "ic"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "typescript": "^5.8.3"
  }
}
