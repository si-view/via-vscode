{
  "name": "via-vscode",
  "displayName": "SKILL Runner - Via",
  "description": "Run Cadence SKILL.",
  "version": "0.0.2",
  "publisher": "si-view",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/si-view/via-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/si-view/via-vscode/issues"
  },
  "homepage": "https://github.com/si-view/via-vscode#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:skill",
    "onCommand:via.configureWorkspace",
    "onCommand:via.configureSession",
    "onCommand:via.selectWorkspace",
    "onCommand:via.createWorkspace",
    "onCommand:via.showStatusMenu",
    "onCommand:via.showStatusDetails",
    "onCommand:via.refreshConnectionStatus",
    "onCommand:via.refreshSessions",
    "onCommand:via.selectSession",
    "onCommand:via.killSession",
    "onCommand:via.startWorkspaceFromSessions",
    "onCommand:via.startWorkspace",
    "onCommand:via.startKernel",
    "onCommand:via.runFile",
    "onCommand:via.runSelection",
    "onView:via.interactiveView",
    "onView:via.sessionsView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "via.configureWorkspace",
        "title": "VIA: Configure Workspace",
        "category": "VIA",
        "icon": "$(gear)"
      },
      {
        "command": "via.selectWorkspace",
        "title": "VIA: Select Workspace",
        "category": "VIA",
        "icon": "$(server-process)"
      },
      {
        "command": "via.createWorkspace",
        "title": "VIA: New Workspace",
        "category": "VIA",
        "icon": "$(add)"
      },
      {
        "command": "via.startWorkspace",
        "title": "VIA: Start Workspace",
        "category": "VIA",
        "icon": "$(debug-start)"
      },
      {
        "command": "via.refreshConnectionStatus",
        "title": "VIA: Refresh Connection Status",
        "category": "VIA",
        "icon": "$(refresh)"
      },
      {
        "command": "via.showStatusDetails",
        "title": "VIA: Show Status Details",
        "category": "VIA",
        "icon": "$(list-unordered)"
      },
      {
        "command": "via.runFile",
        "title": "VIA: Run Current File",
        "category": "VIA",
        "icon": "$(play)"
      },
      {
        "command": "via.runSelection",
        "title": "VIA: Run Selection or Paragraph",
        "category": "VIA",
        "icon": "$(run-all)"
      },
      {
        "command": "via.focusInteractiveView",
        "title": "VIA: Open Interactive SKILL",
        "category": "VIA",
        "icon": "$(terminal-view-icon)"
      },
      {
        "command": "via.runInteractiveSkill",
        "title": "VIA: Run Interactive SKILL",
        "category": "VIA",
        "icon": "$(play)"
      },
      {
        "command": "via.clearInteractiveSkill",
        "title": "VIA: Clear Interactive SKILL",
        "category": "VIA",
        "icon": "$(clear-all)"
      },
      {
        "command": "via.refreshSessions",
        "title": "VIA: Refresh Sessions",
        "category": "VIA",
        "icon": "$(refresh)"
      },
      {
        "command": "via.selectSession",
        "title": "VIA: Select Session",
        "category": "VIA",
        "icon": "$(check)"
      },
      {
        "command": "via.killSession",
        "title": "VIA: Kill Session",
        "category": "VIA",
        "icon": "$(trash)"
      },
      {
        "command": "via.startWorkspaceFromSessions",
        "title": "VIA: Start Workspace",
        "category": "VIA",
        "icon": "$(debug-start)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "viaSidebar",
          "title": "VIA",
          "icon": "$(terminal-view-icon)"
        }
      ],
      "panel": [
        {
          "id": "viaPanel",
          "title": "VIA",
          "icon": "$(terminal-view-icon)"
        }
      ]
    },
    "views": {
      "viaSidebar": [
        {
          "id": "via.sessionsView",
          "name": "Virtuoso Sessions"
        }
      ],
      "viaPanel": [
        {
          "type": "webview",
          "id": "via.interactiveView",
          "name": "Interactive SKILL"
        }
      ]
    },
    "configuration": {
      "title": "SKILL Runner",
      "properties": {
        "via.commandPath": {
          "type": "string",
          "default": "",
          "description": "Path to the via executable. Leave empty to use the via binary bundled with this extension."
        },
        "via.language": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "zh"
          ],
          "default": "auto",
          "markdownDescription": "Language used by the SKILL Runner runtime UI. `auto` follows the VS Code display language."
        },
        "via.defaultWorkspace": {
          "type": "string",
          "default": "",
          "description": "Default Virtuoso workspace path used when starting via."
        },
        "via.defaultInstanceName": {
          "type": "string",
          "default": "vscode",
          "description": "Default via instance name used behind the scenes."
        },
        "via.displayMode": {
          "type": "string",
          "enum": [
            "inherit",
            "custom",
            "unset"
          ],
          "default": "inherit",
          "description": "How DISPLAY is passed to via commands."
        },
        "via.displayValue": {
          "type": "string",
          "default": "",
          "description": "DISPLAY value used when via.displayMode is set to custom, for example :0 or localhost:10.0."
        },
        "via.environmentScript": {
          "type": "string",
          "default": "",
          "description": "Path to a shell script sourced before running via commands. Use it to export Virtuoso, license, and other environment variables."
        },
        "via.environmentScriptShell": {
          "type": "string",
          "enum": [
            "auto",
            "bash",
            "sh",
            "zsh",
            "csh",
            "tcsh"
          ],
          "default": "auto",
          "description": "Shell used to source via.environmentScript. auto uses the user's default SHELL and loads its rc file when supported."
        },
        "via.knownWorkspaces": {
          "type": "array",
          "default": [],
          "description": "Known via workspace presets shown in the workspace selector.",
          "items": {
            "type": "object",
            "properties": {
              "instanceName": {
                "type": "string"
              },
              "workspacePath": {
                "type": "string"
              }
            }
          }
        },
        "via.knownKernels": {
          "type": "array",
          "default": [],
          "description": "Known via workspace presets shown in the workspace selector.",
          "deprecationMessage": "Use via.knownWorkspaces instead.",
          "items": {
            "type": "object",
            "properties": {
              "instanceName": {
                "type": "string"
              },
              "workspacePath": {
                "type": "string"
              }
            }
          }
        },
        "via.autoStartWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "Start via automatically for the selected workspace before running a file or selection when needed."
        },
        "via.loadOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically load saved .il files with via send --load."
        },
        "via.useDisplay": {
          "type": "boolean",
          "default": true,
          "description": "Whether to pass DISPLAY to via commands.",
          "deprecationMessage": "Use via.displayMode instead."
        },
        "via.autoStartKernel": {
          "type": "boolean",
          "default": true,
          "description": "Start via automatically for the selected workspace before running a file or selection when needed.",
          "deprecationMessage": "Use via.autoStartWorkspace instead."
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "via.runSelection",
          "when": "resourceExtname == .il && editorHasSelection",
          "group": "navigation@10"
        }
      ],
      "editor/title": [
        {
          "command": "via.selectWorkspace",
          "when": "resourceExtname == .il",
          "group": "navigation@9"
        },
        {
          "command": "via.runFile",
          "when": "resourceExtname == .il",
          "group": "navigation@10"
        },
        {
          "command": "via.runSelection",
          "when": "resourceExtname == .il",
          "group": "navigation@11"
        }
      ],
      "view/title": [
        {
          "command": "via.refreshSessions",
          "when": "view == via.sessionsView",
          "group": "navigation@1"
        },
        {
          "command": "via.startWorkspaceFromSessions",
          "when": "view == via.sessionsView",
          "group": "navigation@2"
        },
        {
          "command": "via.runInteractiveSkill",
          "when": "view == via.interactiveView",
          "group": "navigation@1"
        },
        {
          "command": "via.clearInteractiveSkill",
          "when": "view == via.interactiveView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "via.selectSession",
          "when": "view == via.sessionsView && viewItem == viaSession",
          "group": "inline@1"
        },
        {
          "command": "via.killSession",
          "when": "view == via.sessionsView && viewItem == viaSession",
          "group": "inline@2"
        }
      ],
      "commandPalette": [
        {
          "command": "via.configureWorkspace"
        },
        {
          "command": "via.startWorkspace"
        },
        {
          "command": "via.refreshConnectionStatus"
        },
        {
          "command": "via.refreshSessions"
        },
        {
          "command": "via.showStatusDetails"
        },
        {
          "command": "via.selectWorkspace"
        },
        {
          "command": "via.createWorkspace"
        },
        {
          "command": "via.runFile"
        },
        {
          "command": "via.runSelection"
        },
        {
          "command": "via.focusInteractiveView"
        },
        {
          "command": "via.runInteractiveSkill"
        },
        {
          "command": "via.clearInteractiveSkill"
        }
      ]
    },
    "languages": [
      {
        "id": "skill",
        "aliases": [
          "Skill"
        ],
        "extensions": [
          ".il"
        ]
      }
    ]
  },
  "files": [
    "dist",
    "bin",
    "LICENSE",
    "media/icon.png",
    "media/qrcode.jpg",
    "media/VIAWorkSpace.gif",
    "media/RunningParagraph.gif",
    "media/LoadOnSave.png",
    "README.md",
    "README.zh-CN.md",
    "package.json"
  ],
  "scripts": {
    "vscode:prepublish": "npm run build:package",
    "download:via": "node ./scripts/download-via.js",
    "download:via:all-linux": "node ./scripts/download-via.js --all-linux",
    "build": "npm run download:via && tsc -p ./",
    "build:package": "npm run download:via:all-linux && tsc -p ./",
    "package": "vsce package --no-dependencies",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "npm run lint"
  },
  "keywords": [
    "via",
    "virtuoso",
    "skill",
    "ic",
    "cadence"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.8.3"
  }
}
